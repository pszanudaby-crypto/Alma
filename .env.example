# ─── Alma API / Amvera ───────────────────────────────────────────────────────
# Для локального Vite можно оставить пустым: запросы /api проксируются на localhost:8080.
# Для Vercel укажите URL backend на Amvera, например https://alma-api.amvera.io
VITE_API_URL=

# PostgreSQL на Amvera или локально
DATABASE_URL=postgres://user:password@host:5432/dbname

# Любая длинная случайная строка. Хранить как secret.
JWT_SECRET=change-me-to-a-long-random-string

# Через запятую: email-адреса, которые должны становиться admin при регистрации.
# Первый зарегистрированный пользователь также автоматически получает роль admin.
ADMIN_EMAILS=
ADMIN_USERNAME=admin

# Если указать, миграция создаст/обновит admin-пользователя при старте.
ADMIN_PASSWORD=

# Если frontend и backend на разных доменах, укажите origin фронта.
CORS_ORIGIN=http://localhost:5173

# Production URL приложения нужен для публичных ссылок на загруженные медиа.
PUBLIC_APP_URL=http://localhost:8080

# Папка для загруженных файлов. На Amvera используйте persistent storage, например /data/uploads.
MEDIA_DIR=./server/uploads
