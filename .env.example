# ─── Supabase ────────────────────────────────────────────────────────────────
# Скопируйте этот файл в .env и заполните значениями из Project Settings → API Keys

# URL проекта (Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key — безопасен для фронтенда (новый формат sb_publishable_...)
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# ⚠️  Secret key (sb_secret_...) — НИКОГДА не добавляйте в этот файл.
#     Он используется только на сервере (Edge Functions, backend).
